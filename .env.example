# Standard environment (server-only; NEVER prefix Xero/Supabase/Anthropic with NEXT_PUBLIC_).
# Copy to .env.local and fill in. See ARCHITECTURE-SPINE.md "Xero API Surface" + AD-8/AD-10.

# --- Xero OAuth2 (Track A) ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Must exactly match a redirect URI registered on the Xero app.
XERO_REDIRECT_URI=http://localhost:3000/api/connect/callback
# Fixed submission scope set (AD-10). Non-`.read` variants cover read+write;
# accounting.reports.read is read-only. Requested exactly at connect (Story 1.1).
XERO_SCOPES="offline_access accounting.contacts accounting.transactions accounting.settings accounting.reports.read"
# Optional: fallback base currency if none can be inferred from the ledger.
XERO_BASE_CURRENCY=USD
# Optional: rate-budget overrides (NFR-RateLimit). Defaults 1000 / 950.
# XERO_DAILY_CAP=1000
# XERO_DAILY_SOFT_CAP=950

# --- Supabase (server-side store; AD-8) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (attribution + drafted fix; other track) ---
ANTHROPIC_API_KEY=

# --- Demo toggles ---
# Serve the mock Verdict so the UI is demoable with zero backend.
NEXT_PUBLIC_USE_MOCK_VERDICT=true
